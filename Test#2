        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            if state then
                if not part:GetAttribute("OriginalMaterial") then
                    part:SetAttribute("OriginalMaterial", part.Material)
                    part:SetAttribute("OriginalTransparency", part.Transparency)
                end
                part.Material = Enum.Material.Neon
                part.Transparency = 0.3
            else
                local mat = part:GetAttribute("OriginalMaterial")
                local trans = part:GetAttribute("OriginalTransparency")
                if mat then
                    part.Material = mat
                    part.Transparency = trans or 0
                end
            end
        end
    end
end

-- ========== СОЗДАНИЕ UI ЭЛЕМЕНТОВ ==========
addCheckbox("Main", "ESP (Enemies Only)", false, function(state)
    espEnabled = state
    updateESP(state)
end)

addSlider("Main", "Fast Speed", 16, 250, 54, function(value)
    setSpeed(value)
end)

addSlider("Main", "Super Jump", 50, 250, 65, function(value)
    setJump(value)
end)

addCheckbox("Main", "Hitbox Expander (ON / OFF)", false, function(state)
    hitboxEnabled = state
    updateHitbox(state)
end)

addSlider("Main", "Hitbox Size", 1, 1000, 4, function(value)
    hitboxSize = value
    if hitboxEnabled then
        updateHitbox(true)
    end
end)

addCheckbox("Misc", "X-Ray Vision (Wallhack)", false, function(state)
    xrayEnabled = state
    updateXRay(state)
end)

