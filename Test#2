-- Функция создания чекбокса
local function addCheckbox(tab, labelText, defaultValue, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 35)
    frame.Position = UDim2.new(0, 10, 0, #contentContainer:GetChildren() * 40)
    frame.BackgroundTransparency = 1
    frame.Parent = contentContainer
    frame:SetAttribute("Tab", tab)
    
    local checkbox = Instance.new("TextButton")
    checkbox.Size = UDim2.new(0, 22, 0, 22)
    checkbox.Position = UDim2.new(0, 0, 0, 6)
    checkbox.Text = ""
    checkbox.BackgroundColor3 = defaultValue and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(60, 60, 60)
    checkbox.BorderSizePixel = 0
    checkbox.Parent = frame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -30, 1, 0)
    label.Position = UDim2.new(0, 30, 0, 0)
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(230, 230, 230)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.Parent = frame
    
    local checked = defaultValue
    checkbox.MouseButton1Click:Connect(function()
        checked = not checked
        checkbox.BackgroundColor3 = checked and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(60, 60, 60)
        callback(checked)
    end)
    
    return { setValue = function(v) checked = v; checkbox.BackgroundColor3 = checked and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(60, 60, 60); callback(checked) end }
end

-- Функция создания слайдера
local function addSlider(tab, labelText, minVal, maxVal, defaultVal, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 60)
    frame.Position = UDim2.new(0, 10, 0, #contentContainer:GetChildren() * 65)
    frame.BackgroundTransparency = 1
    frame.Parent = contentContainer
    frame:SetAttribute("Tab", tab)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 25)
    label.Text = labelText .. ": " .. tostring(defaultVal)
    label.TextColor3 = Color3.fromRGB(230, 230, 230)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.Parent = frame
    
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(1, 0, 0, 20)
    sliderFrame.Position = UDim2.new(0, 0, 0, 28)
    sliderFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    sliderFrame.BorderSizePixel = 0
    sliderFrame.Parent = frame
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((defaultVal-minVal)/(maxVal-minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 150, 200)
    fill.BorderSizePixel = 0
    fill.Parent = sliderFrame
    
    local value = defaultVal
    local dragging = false
    
    sliderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local relativeX = math.clamp((input.Position.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
            value = minVal + (maxVal - minVal) * relativeX
            value = math.floor(value)
            fill.Size = UDim2.new(relativeX, 0, 1, 0)
            label.Text = labelText .. ": " .. tostring(value)
            callback(value)
        end
    end)
    
    sliderFrame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    sliderFrame.MouseMoved:Connect(function(x, y)
        if dragging then
            local relativeX = math.clamp((x - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
            value = minVal + (maxVal - minVal) * relativeX
            value = math.floor(value)
            fill.Size = UDim2.new(relativeX, 0, 1, 0)
            label.Text = labelText .. ": " .. tostring(value)
            callback(value)
        end
    end)
    
    return { setValue = function(v) value = v; fill.Size = UDim2.new((v-minVal)/(maxVal-minVal), 0, 1, 0); label.Text = labelText .. ": " .. tostring(v); callback(v) end }
end

-- Функция обновления видимости
local function updateContentVisibility()
    for _, child in pairs(contentContainer:GetChildren()) do
        if child:GetAttribute("Tab") then
            child.Visible = child:GetAttribute("Tab") == activeTab
        end
    end
end

-- ========== ПЕРЕМЕННЫЕ ДЛЯ ФУНКЦИЙ ==========
local espEnabled = false
local espColor = Color3.fromRGB(255, 0, 0)
local speedValue = 54  -- ← как на скриншоте
local jumpPowerValue = 65  -- ← как на скриншоте
local hitboxEnabled = false
local hitboxSize = 4
local xrayEnabled = false

-- ESP
local function updateESP()
    for _, otherPlayer in pairs(game.Players:GetPlayers()) do
        if otherPlayer ~= player then
            local character = otherPlayer.Character
            if character then
                local highlight = character:FindFirstChild("WRANNE_ESP")
                if espEnabled then
                    if not highlight then
                        highlight = Instance.new("Highlight")
                        highlight.Name = "WRANNE_ESP"
                        highlight.FillColor = espColor
                        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                        highlight.FillTransparency = 0.5
                        highlight.Parent = character
                    end
                else
                    if highlight then highlight:Destroy() end
                end
            end
        end
    end
end

local function setESPColor(color)
    espColor = color
    for _, otherPlayer in pairs(game.Players:GetPlayers()) do
        if otherPlayer ~= player then
            local character = otherPlayer.Character
            if character then
                local highlight = character:FindFirstChild("WRANNE_ESP")
                if highlight then
                    highlight.FillColor = color
                end
            end
        end
    end
end

-- Скорость
local function setSpeed(speed)
    speedValue = speed
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = speed
        end
    end
end

-- Супер прыжок
local function setJumpPower(power)
    jumpPowerValue = power
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.JumpPower = power
        end
    end
end

-- Hitbox Expander
local function updateHitbox()
    for _, otherPlayer in pairs(game.Players:GetPlayers()) do
        if otherPlayer ~= player then
            local character = otherPlayer.Character
            if character then
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        if hitboxEnabled then
                            local size = part.Size
                            part.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                            part:SetAttribute("OriginalSize", size)
                        else
                            local original = part:GetAttribute("OriginalSize")
                            if original then
                                part.Size = original
                            end
                        end
                    end
                end
            end
        end
    end
end

-- X-Ray Vision
local function updateXRay()
    for _, part in pairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            if xrayEnabled then
                if not part:GetAttribute("OriginalMaterial") then
                    part:SetAttribute("OriginalMaterial", part.Material)
                    part:SetAttribute("OriginalTransparency", part.Transparency)
                end
                part.Material = Enum.Material.Neon
                part.Transparency = 0.3
            else
                local originalMat = part:GetAttribute("OriginalMaterial")
                local originalTrans = part:GetAttribute("OriginalTransparency")
                if originalMat then
                    part.Material = originalMat
                    part.Transparency = originalTrans or 0
                end
            end
        end
    end
end

