local UIS = game:GetService("UserInputService")
local localPlayer = Players.LocalPlayer
local camera = workspace.CurrentCamera

-- ========== ПЕРЕМЕННЫЕ ==========
local espEnabled = false
local flyEnabled = false
local noclipEnabled = false
local flyConn = nil
local velocity = nil
local walkSpeed = 16
local flySpeed = 70
local espHighlights = {}
local hitboxEnabled = false
local hitboxSize = 4
local hitboxParts = {}
local xrayEnabled = false
local aimbotEnabled = false
local espColor = Color3.fromRGB(255, 0, 0)

-- ========== ESP (ТОЛЬКО КОНТУР) ==========
local function updateESP()
    for player, hl in pairs(espHighlights) do
        if hl and hl.Parent then hl:Destroy() end
    end
    espHighlights = {}
    
    if not espEnabled then return end
    
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= localPlayer then
            local char = otherPlayer.Character
            if char then
                local hl = Instance.new("Highlight")
                hl.Name = "WRANNE_ESP"
                hl.FillTransparency = 1
                hl.OutlineColor = espColor
                hl.OutlineTransparency = 0
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                hl.Parent = char
                espHighlights[otherPlayer] = hl
            end
        end
    end
end

-- ========== HITBOX EXPANDER (СФЕРА, А НЕ КУБ) ==========
local function updateHitbox()
    -- Удаляем старые хитбоксы
    for _, data in pairs(hitboxParts) do
        if data.part then data.part:Destroy() end
        if data.connection then data.connection:Disconnect() end
    end
    hitboxParts = {}
    
    if not hitboxEnabled then return end
    
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= localPlayer then
            local char = otherPlayer.Character
            if char then
                -- Ищем часть тела для привязки
                local attachPart = char:FindFirstChild("HumanoidRootPart") or 
                                   char:FindFirstChild("UpperTorso") or 
                                   char:FindFirstChild("LowerTorso") or 
                                   char:FindFirstChild("Torso")
                
                if attachPart then
                    -- СОЗДАЁМ СФЕРУ (Ball) вместо куба
                    local hitboxPart = Instance.new("Part")
                    hitboxPart.Shape = Enum.PartType.Ball  -- ← ГЛАВНОЕ! СФЕРА!
                    hitboxPart.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                    hitboxPart.Transparency = 1  -- полностью невидимая
                    hitboxPart.CanCollide = false
                    hitboxPart.Anchored = false
                    hitboxPart.Name = "WRANNE_Hitbox"
                    hitboxPart.Parent = char
                    
                    -- Привязываем к части тела
                    local weld = Instance.new("Weld")
                    weld.Part0 = attachPart
                    weld.Part1 = hitboxPart
                    weld.C0 = CFrame.new(0, 0, 0)
                    weld.Parent = hitboxPart
                    
                    table.insert(hitboxParts, {part = hitboxPart, player = otherPlayer})
                    
                    -- Следим за перерождением
                    local conn = otherPlayer.CharacterAdded:Connect(function(newChar)
                        task.wait(0.5)
                        if hitboxEnabled then
                            local newAttach = newChar:FindFirstChild("HumanoidRootPart") or 
                                              newChar:FindFirstChild("UpperTorso") or 
                                              newChar:FindFirstChild("LowerTorso") or 
                                              newChar:FindFirstChild("Torso")
                            if newAttach then
                                local newHitbox = Instance.new("Part")
                                newHitbox.Shape = Enum.PartType.Ball  -- СФЕРА
                                newHitbox.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                                newHitbox.Transparency = 1
                                newHitbox.CanCollide = false
                                newHitbox.Name = "WRANNE_Hitbox"
                                newHitbox.Parent = newChar
                                
                                local newWeld = Instance.new("Weld")
                                newWeld.Part0 = newAttach
                                newWeld.Part1 = newHitbox
                                newWeld.C0 = CFrame.new(0, 0, 0)
                                newWeld.Parent = newHitbox
                                
                                table.insert(hitboxParts, {part = newHitbox, player = otherPlayer})
                            end
                        end
                    end)
                    table.insert(hitboxParts, {connection = conn})
                end
            end
        end
    end
end

local function setHitboxSize(size)
    hitboxSize = size
    if hitboxEnabled then
        for _, data in pairs(hitboxParts) do
            if data.part then
                data.part.Size = Vector3.new(size, size, size)
            end
        end
    end
end

-- ========== X-RAY ==========
local function updateXRay()
    for _, part in pairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "WRANNE_Hitbox" then
            if xrayEnabled then
                if not part:GetAttribute("OriginalMaterial") then
                    part:SetAttribute("OriginalMaterial", part.Material)
                    part:SetAttribute("OriginalTransparency", part.Transparency)
                end
                part.Material = Enum.Material.Neon
                part.Transparency = 0.3
            else
                local mat = part:GetAttribute("OriginalMaterial")
                local trans = part:GetAttribute("OriginalTransparency")
                if mat then
                    part.Material = mat
                    part.Transparency = trans or 0
                end
            end
        end
    end
end

-- ========== ФУНКЦИИ ==========
local function setSpeed(speed)
    walkSpeed = speed
    local char = localPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = speed end
    end
end

local function toggleFly()
    local char = localPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart") or 
                 char:FindFirstChild("UpperTorso") or 
                 char:FindFirstChild("LowerTorso")
    if not hrp then return end
    
    if flyConn then flyConn:Disconnect() end
    if velocity then velocity:Destroy() end
    
    if flyEnabled then
        velocity = Instance.new("BodyVelocity")
        velocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        velocity.Velocity = Vector3.zero
        velocity.Parent = hrp
        flyConn = RunService.RenderStepped:Connect(function()
            local camCF = camera.CFrame
            local move = Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W) then move += camCF.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then move -= camCF.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then move -= camCF.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then move += camCF.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0, 1, 0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.new(0, 1, 0) end
            velocity.Velocity = move.Magnitude > 0 and move.Unit * flySpeed or Vector3.zero
        end)
    end
end

local noclipConn = nil
local function toggleNoclip()
    if noclipConn then noclipConn:Disconnect() end
    if noclipEnabled then
        noclipConn = RunService.Stepped:Connect(function()
            if localPlayer.Character then
                for _, part in ipairs(localPlayer.Character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
end

-- ========== AIMBOT ==========
local aimbotEnabled = false
local Aimbot = { Radius = 120, TargetPart = "Head" }

RunService.RenderStepped:Connect(function()
    local mouseDown = UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    if mouseDown and aimbotEnabled then
        local closest, dist = nil, Aimbot.Radius
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= localPlayer and player.Character then
                local part = player.Character:FindFirstChild(Aimbot.TargetPart)
                local hum = player.Character:FindFirstChildOfClass("Humanoid")
                if part and hum and hum.Health > 0 then
                    local pos, visible = camera:WorldToViewportPoint(part.Position)
                    if visible then
                        local mag = (Vector2.new(pos.X, pos.Y) - UIS:GetMouseLocation()).Magnitude
                        if mag < dist then
                            dist = mag
                            closest = part
                        end
                    end
                end
            end
        end
        if closest then
            camera.CFrame = CFrame.new(camera.CFrame.Position, closest.Position)
        end
    end
end)

-- ========== ОБНОВЛЕНИЕ ПРИ РАУНДЕ ==========
local function onCharacterAdded()
    task.wait(0.5)
    setSpeed(walkSpeed)
    if flyEnabled then toggleFly() end
    if noclipEnabled then toggleNoclip() end
    if espEnabled then updateESP() end
    if hitboxEnabled then updateHitbox() end
    if xrayEnabled then updateXRay() end
end

localPlayer.CharacterAdded:Connect(onCharacterAdded)

Players.PlayerAdded:Connect(function(player)
    task.wait(0.5)
    if espEnabled then updateESP() end
    if hitboxEnabled then updateHitbox() end
end)

Players.PlayerRemoving:Connect(function(player)
    if espHighlights[player] then
        espHighlights[player]:Destroy()
        espHighlights[player] = nil
    end
end)

