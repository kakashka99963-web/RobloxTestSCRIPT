local function updateContentVisibility()
    for _, child in pairs(contentContainer:GetChildren()) do
        if child:GetAttribute("Tab") then
            child.Visible = child:GetAttribute("Tab") == activeTab
        end
    end
end

-- Функция создания чекбокса
local function addCheckbox(tab, labelText, defaultValue, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 40)
    frame.Position = UDim2.new(0, 10, 0, #contentContainer:GetChildren() * 45)
    frame.BackgroundTransparency = 1
    frame.Parent = contentContainer
    frame:SetAttribute("Tab", tab)
    
    local checkbox = Instance.new("TextButton")
    checkbox.Size = UDim2.new(0, 24, 0, 24)
    checkbox.Position = UDim2.new(0, 0, 0, 8)
    checkbox.Text = ""
    checkbox.BackgroundColor3 = defaultValue and Color3.fromRGB(80, 180, 80) or Color3.fromRGB(50, 50, 70)
    checkbox.BorderSizePixel = 1
    checkbox.BorderColor3 = Color3.fromRGB(100, 100, 120)
    checkbox.Parent = frame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -35, 1, 0)
    label.Position = UDim2.new(0, 35, 0, 0)
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(230, 230, 230)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 15
    label.Parent = frame
    
    local checked = defaultValue
    checkbox.MouseButton1Click:Connect(function()
        checked = not checked
        checkbox.BackgroundColor3 = checked and Color3.fromRGB(80, 180, 80) or Color3.fromRGB(50, 50, 70)
        callback(checked)
    end)
    
    return { setValue = function(v) checked = v; checkbox.BackgroundColor3 = checked and Color3.fromRGB(80, 180, 80) or Color3.fromRGB(50, 50, 70); callback(checked) end }
end

-- Функция создания слайдера
local function addSlider(tab, labelText, minVal, maxVal, defaultVal, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 65)
    frame.Position = UDim2.new(0, 10, 0, #contentContainer:GetChildren() * 70)
    frame.BackgroundTransparency = 1
    frame.Parent = contentContainer
    frame:SetAttribute("Tab", tab)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 25)
    label.Text = labelText .. ": " .. tostring(defaultVal)
    label.TextColor3 = Color3.fromRGB(230, 230, 230)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 15
    label.Parent = frame
    
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(1, 0, 0, 25)
    sliderFrame.Position = UDim2.new(0, 0, 0, 30)
    sliderFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
    sliderFrame.BorderSizePixel = 0
    sliderFrame.Parent = frame
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((defaultVal-minVal)/(maxVal-minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(80, 150, 220)
    fill.BorderSizePixel = 0
    fill.Parent = sliderFrame
    
    local value = defaultVal
    local dragging = false
    
    sliderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local relativeX = math.clamp((input.Position.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
            value = math.floor(minVal + (maxVal - minVal) * relativeX + 0.5)
            fill.Size = UDim2.new(relativeX, 0, 1, 0)
            label.Text = labelText .. ": " .. tostring(value)
            callback(value)
        end
    end)
    
    sliderFrame.InputEnded:Connect(function()
        dragging = false
    end)
    
    sliderFrame.MouseMoved:Connect(function(x, y)
        if dragging then
            local relativeX = math.clamp((x - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
            value = math.floor(minVal + (maxVal - minVal) * relativeX + 0.5)
            fill.Size = UDim2.new(relativeX, 0, 1, 0)
            label.Text = labelText .. ": " .. tostring(value)
            callback(value)
        end
    end)
    
    return { setValue = function(v) value = v; fill.Size = UDim2.new((v-minVal)/(maxVal-minVal), 0, 1, 0); label.Text = labelText .. ": " .. tostring(v); callback(v) end }
end

-- ========== ПЕРЕМЕННЫЕ ==========
local espEnabled = false
local speedValue = 54
local jumpValue = 65
local hitboxEnabled = false
local hitboxSize = 4  -- размер хитбокса в студиях
local xrayEnabled = false

-- ========== ИСПРАВЛЕННЫЙ HITBOX EXPANDER ==========
-- Создаём невидимые части-хитбоксы вокруг игроков
local hitboxParts = {}  -- храним созданные хитбоксы

local function updateHitbox()
    -- Удаляем старые хитбоксы
    for _, data in pairs(hitboxParts) do
        if data.part then data.part:Destroy() end
        if data.connection then data.connection:Disconnect() end
    end
    hitboxParts = {}
    
    if not hitboxEnabled then return end
    
    for _, otherPlayer in pairs(game.Players:GetPlayers()) do
        if otherPlayer ~= player then
            local char = otherPlayer.Character
            if char then
                local rootPart = char:FindFirstChild("HumanoidRootPart")
                if rootPart then
                    -- Создаём невидимую часть-хитбокс
                    local hitboxPart = Instance.new("Part")
                    hitboxPart.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                    hitboxPart.Transparency = 1  -- полностью невидимая
                    hitboxPart.CanCollide = false
                    hitboxPart.Anchored = false
                    hitboxPart.Name = "WRANNE_Hitbox"
                    hitboxPart.Parent = char
                    
                    -- Привязываем к персонажу
                    local weld = Instance.new("Weld")
                    weld.Part0 = rootPart
                    weld.Part1 = hitboxPart
                    weld.C0 = CFrame.new(0, 0, 0)
                    weld.Parent = hitboxPart
                    
                    -- Сохраняем для удаления
                    table.insert(hitboxParts, {
                        part = hitboxPart,
                        player = otherPlayer
                    })
                    
                    -- Следим за перерождением игрока
                    local connection
                    connection = otherPlayer.CharacterAdded:Connect(function(newChar)
                        wait(0.5)
                        local newRoot = newChar:FindFirstChild("HumanoidRootPart")
                        if newRoot and hitboxEnabled then
                            local newHitbox = Instance.new("Part")
                            newHitbox.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                            newHitbox.Transparency = 1
                            newHitbox.CanCollide = false
                            newHitbox.Name = "WRANNE_Hitbox"
                            newHitbox.Parent = newChar
                            
                            local newWeld = Instance.new("Weld")
                            newWeld.Part0 = newRoot
                            newWeld.Part1 = newHitbox
                            newWeld.C0 = CFrame.new(0, 0, 0)
                            newWeld.Parent = newHitbox
                            
                            table.insert(hitboxParts, {
                                part = newHitbox,
                                player = otherPlayer
                            })
                        end
                    end)
                    
                    table.insert(hitboxParts, {connection = connection})
                end
            end
        end
    end
end

-- Обновляем размер хитбокса при изменении слайдера
local function setHitboxSize(size)
    hitboxSize = size
    if hitboxEnabled then
        for _, data in pairs(hitboxParts) do
            if data.part then
                data.part.Size = Vector3.new(size, size, size)
            end
        end
    end
end

-- ========== ОСТАЛЬНЫЕ ФУНКЦИИ ==========
local function setSpeed(speed)
    speedValue = speed
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = speed
    end
end

local function setJump(power)
    jumpValue = power
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.JumpPower = power
    end
end

local function updateESP(state)
    for _, otherPlayer in pairs(game.Players:GetPlayers()) do
        if otherPlayer ~= player then
            local char = otherPlayer.Character
            if char then
                local hl = char:FindFirstChild("WRANNE_ESP")
                if state then
                    if not hl then
                        hl = Instance.new("Highlight")
                        hl.Name = "WRANNE_ESP"
                        hl.FillColor = Color3.fromRGB(255, 0, 0)
                        hl.FillTransparency = 0.5
                        hl.Parent = char
                    end
                else
                    if hl then hl:Destroy() end
                end
            end
        end
    end
end

local function updateXRay(state)
    for _, part in pairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and part.Name ~= "WRANNE_Hitbox" then
            if state then
                if not part:GetAttribute("OriginalMaterial") then
                    part:SetAttribute("OriginalMaterial", part.Material)
                    part:SetAttribute("OriginalTransparency", part.Transparency)
                end
                part.Material = Enum.Material.Neon
                part.Transparency = 0.3
            else
                local mat = part:GetAttribute("OriginalMaterial")
                local trans = part:GetAttribute("OriginalTransparency")
                if mat then
                    part.Material = mat
                    part.Transparency = trans or 0
                end
            end
        end
    end
end

