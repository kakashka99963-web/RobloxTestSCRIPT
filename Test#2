-- ========== ВКЛАДКИ ==========
local tabs = {"Main", "Misc"}
local activeTab = "Main"

local function switchTab(tabName)
    activeTab = tabName
    for _, child in pairs(contentContainer:GetChildren()) do
        if child:GetAttribute("Tab") then
            child.Visible = child:GetAttribute("Tab") == tabName
        end
    end
end

-- Кнопки вкладок
for i, tabName in ipairs(tabs) do
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 100, 1, 0)
    btn.Position = UDim2.new(0, (i-1)*100, 0, 0)
    btn.Text = tabName
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.BackgroundColor3 = tabName == "Main" and Color3.fromRGB(60, 60, 80) or Color3.fromRGB(40, 40, 60)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Parent = tabBar
    
    btn.MouseButton1Click:Connect(function()
        for _, b in pairs(tabBar:GetChildren()) do
            if b:IsA("TextButton") then
                b.BackgroundColor3 = b.Text == tabName and Color3.fromRGB(60, 60, 80) or Color3.fromRGB(40, 40, 60)
            end
        end
        switchTab(tabName)
    end)
end

-- Функция добавления чекбокса
local function addCheckbox(tab, text, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 35)
    frame.Position = UDim2.new(0, 10, 0, #contentContainer:GetChildren() * 40)
    frame.BackgroundTransparency = 1
    frame.Parent = contentContainer
    frame:SetAttribute("Tab", tab)
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 22, 0, 22)
    btn.Position = UDim2.new(0, 0, 0, 6)
    btn.Text = ""
    btn.BackgroundColor3 = default and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(60, 60, 60)
    btn.BorderSizePixel = 0
    btn.Parent = frame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -30, 1, 0)
    label.Position = UDim2.new(0, 30, 0, 0)
    label.Text = text
    label.TextColor3 = Color3.fromRGB(230, 230, 230)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.Parent = frame
    
    local checked = default
    btn.MouseButton1Click:Connect(function()
        checked = not checked
        btn.BackgroundColor3 = checked and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(60, 60, 60)
        callback(checked)
    end)
    callback(default)
end

-- Функция добавления слайдера
local function addSlider(tab, text, minVal, maxVal, defaultVal, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 60)
    frame.Position = UDim2.new(0, 10, 0, #contentContainer:GetChildren() * 65)
    frame.BackgroundTransparency = 1
    frame.Parent = contentContainer
    frame:SetAttribute("Tab", tab)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 25)
    label.Text = text .. ": " .. tostring(defaultVal)
    label.TextColor3 = Color3.fromRGB(230, 230, 230)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.Parent = frame
    
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(1, 0, 0, 20)
    sliderFrame.Position = UDim2.new(0, 0, 0, 28)
    sliderFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    sliderFrame.BorderSizePixel = 0
    sliderFrame.Parent = frame
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((defaultVal-minVal)/(maxVal-minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 150, 200)
    fill.BorderSizePixel = 0
    fill.Parent = sliderFrame
    
    local value = defaultVal
    local dragging = false
    
    sliderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local relativeX = math.clamp((input.Position.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
            value = math.floor(minVal + (maxVal - minVal) * relativeX)
            fill.Size = UDim2.new(relativeX, 0, 1, 0)
            label.Text = text .. ": " .. tostring(value)
            callback(value)
        end
    end)
    
    sliderFrame.InputEnded:Connect(function()
        dragging = false
    end)
    
    sliderFrame.MouseMoved:Connect(function(x, y)
        if dragging then
            local relativeX = math.clamp((x - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
            value = math.floor(minVal + (maxVal - minVal) * relativeX)
            fill.Size = UDim2.new(relativeX, 0, 1, 0)
            label.Text = text .. ": " .. tostring(value)
            callback(value)
        end
    end)
    
    callback(defaultVal)
end

-- ========== ФУНКЦИИ ==========
local speedValue = 54
local jumpValue = 65
local hitboxSize = 4
local hitboxEnabled = false
local espEnabled = false

-- Скорость
local function setSpeed(speed)
    speedValue = speed
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = speed
    end
end

-- Прыжок
local function setJump(power)
    jumpValue = power
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.JumpPower = power
    end
end

-- ESP
local function updateESP(state)
    for _, otherPlayer in pairs(game.Players:GetPlayers()) do
        if otherPlayer ~= player then
            local char = otherPlayer.Character
            if char then
                local hl = char:FindFirstChild("WRANNE_ESP")
                if state then
                    if not hl then
                        hl = Instance.new("Highlight")
                        hl.Name = "WRANNE_ESP"
                        hl.FillColor = Color3.fromRGB(255, 0, 0)
                        hl.FillTransparency = 0.5
                        hl.Parent = char
                    end
                else
                    if hl then hl:Destroy() end
                end
            end
        end
    end
end

-- Hitbox
local function updateHitbox(state)
    for _, otherPlayer in pairs(game.Players:GetPlayers()) do
        if otherPlayer ~= player then
            local char = otherPlayer.Character
            if char then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        if state then
                            if not part:GetAttribute("OriginalSize") then
                                part:SetAttribute("OriginalSize", part.Size)
                            end
                            part.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                        else
                            local original = part:GetAttribute("OriginalSize")
                            if original then
                                part.Size = original
                            end
                        end
                    end
                end
            end
        end
    end
end

-- X-Ray
